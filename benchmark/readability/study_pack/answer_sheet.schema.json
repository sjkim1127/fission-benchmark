{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReadabilityStudyResponse",
  "type": "object",
  "required": ["participant_id", "items"],
  "properties": {
    "participant_id": { "type": "string", "minLength": 1 },
    "pilot": { "type": "boolean", "default": true },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["function", "decompiler", "accuracy", "time_sec"],
        "properties": {
          "function": { "type": "string" },
          "decompiler": { "type": "string" },
          "accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
          "time_sec": { "type": "number", "minimum": 0 },
          "confidence": { "type": "integer", "minimum": 1, "maximum": 5 },
          "notes": { "type": "string" }
        }
      }
    },
    "preference": {
      "type": "string",
      "enum": ["ghidra", "fission", "tie", "abstain"]
    }
  }
}
