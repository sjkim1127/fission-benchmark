{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fission.dev/schemas/benchmark-envelope-v2.schema.json",
  "title": "Fission Benchmark Envelope v2",
  "type": "object",
  "required": ["schema_version", "run", "toolchain", "matrix", "validity", "rows"],
  "properties": {
    "schema_version": {"const": 2},
    "run": {
      "type": "object",
      "required": ["official"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "started_at": {"type": "string", "minLength": 1},
        "finished_at": {"type": "string", "minLength": 1},
        "runner_commit": {"type": "string", "minLength": 1},
        "corpus": {"type": "string", "minLength": 1},
        "profile": {"enum": ["diagnostic", "realistic"]},
        "official": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "toolchain": {"type": "object"},
    "matrix": {"type": "object"},
    "validity": {"type": "object", "required": ["valid", "publishable"]},
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decompiler", "function_name", "compiler_variant", "time_ms"],
        "properties": {
          "decompiler": {"type": "string", "minLength": 1},
          "function_name": {"type": "string", "minLength": 1},
          "compiler_variant": {"type": "string", "minLength": 1},
          "semantic_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "source_similarity": {"type": "number", "minimum": 0, "maximum": 1},
          "structural_penalty": {"type": "number", "minimum": 0, "maximum": 1},
          "correctness_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "correctness_rank": {"type": ["integer", "null"], "minimum": 1},
          "time_ms": {"type": "integer", "minimum": 0},
          "cases_passed": {"type": "integer", "minimum": 0},
          "cases_total": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
